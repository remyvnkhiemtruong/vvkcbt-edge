NODE_ENV=development
PORT=3000
DATABASE_URL=postgresql://vnu:vnu_secret@localhost:5432/vnu_exam
# Mat khau user postgres (chi dung khi chay setup-windows.bat, khong dung cho API)
POSTGRES_PASSWORD=
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379
SCHOOL_NAME=THPT Võ Văn Kiệt
JWT_SECRET=change-me-in-production
ANONYMIZATION_SALT=change-me-anonymization-salt
# Bắt buộc — sinh key riêng (node -e "console.log(require('crypto').randomBytes(16).toString('hex'))")
# KHÔNG dùng giá trị mẫu dưới đây cho thi thật
AUDIO_ENCRYPTION_KEY=GENERATE_YOUR_OWN_32_BYTE_HEX_KEY
UPLOAD_DIR=./uploads
BACKUP_DIR=./backups
# Optional: encrypt backup ZIP at rest (outputs .zip.enc)
BACKUP_PASSPHRASE=

# Edge room context (student/proctor auto session)
EDGE_ACTIVE_SESSION_ID=
EDGE_ROOM_NAME=Phòng máy số 1
EDGE_ROOM_CAPACITY=30

# Vite SPAs
VITE_API_URL=
VITE_API_PROXY_TARGET=http://127.0.0.1:3000
VITE_UI_MODE=production
VITE_SCHOOL_NAME=THPT Võ Văn Kiệt
VITE_SO_GD_NAME=SỞ GIÁO DỤC VÀ ĐÀO TẠO CÀ MAU
VITE_SCHOOL_BRAND_NAME=TRƯỜNG THPT VÕ VĂN KIỆT
VITE_PLACE_NAME=Cà Mau
# Logo trường — file gốc: LogoVVK.png (repo root). Chạy: node scripts/sync-branding-assets.mjs
# VITE_SCHOOL_LOGO_URL=

# PDF engine (biên bản phòng, bài thi) — mặc định tự tìm Chrome/Edge trên Windows
# PUPPETEER_EXECUTABLE_PATH=C:\Program Files\Microsoft\Edge\Application\msedge.exe
VITE_PROVINCE_NAME=SỞ GIÁO DỤC VÀ ĐÀO TẠO CÀ MAU
VITE_APP_AUTHOR=Trương Minh Khiêm
VITE_SCHOOL_SHORT=VVK

# Dev only: cho phép đăng nhập proctor/proctor123 không qua hash — KHÔNG set true khi NODE_ENV=production, server sẽ tự chặn khởi động
ALLOW_DEFAULT_PROCTOR=true

# Composer (soạn gói ZIP)
COMPOSER_USER=composer
COMPOSER_PASSWORD=composer123
# Giám thị — tài khoản cố định (dev & production)
PROCTOR_USER=proctor
PROCTOR_PASSWORD=proctor123
# Production: bcrypt hash (npm run hash-password -- yourpass)
ADMIN_PASSWORD_HASH=
PROCTOR_PASSWORD_HASH=
COMPOSER_PASSWORD_HASH=

# CORS whitelist (comma-separated origins, production)
EDGE_ORIGINS=http://localhost,http://127.0.0.1,http://localhost:5173,http://localhost:5174,http://127.0.0.1:5173,http://127.0.0.1:5174

# Deploy profile (native only)
DEPLOY_PROFILE=native
# Bo qua Redis/Bull tren may yeu 4GB (single-node)
EDGE_LIGHTWEIGHT=false

# Dev: bo qua kiem tra IP binding JWT (localhost proxy)
DISABLE_IP_BINDING=true

# Dev only: tu dong mo de môn khi thi sinh bat dau (proctor_at_time) — khong dung production
EDGE_DEV_AUTO_OPEN_SLOTS=true

# Student: browser (Chrome kiosk) | seb
VITE_EXAM_LOCK_MODE=browser

# Optional: filter proctor grid by room
EDGE_ROOM_ID=
